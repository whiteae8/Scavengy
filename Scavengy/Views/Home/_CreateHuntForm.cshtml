@model Scavengy.Models.CreateHuntViewModel

<form hx-post="/Home/CreateHunt"
      hx-target="#createHuntModalContent"
      hx-swap="innerHTML"
      hx-validate="true">
    <div class="modal-body">
        @if (Model.Error != null)
        {
            <div class="alert alert-danger">@Model.Error</div>
        }
        <div class="mb-3">
            <label for="Title" class="form-label">Title</label>
            <input id="Title" name="Title" value="@Model.Form.Title" class="form-control" required />
        </div>
        <div class="mb-3">
            <label for="HuntLocation" class="form-label">Hunt Location</label>
            <input id="HuntLocation" name="HuntLocation" value="@Model.Form.HuntLocation" class="form-control" required />
        </div>
    </div>
    <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary">Create</button>
    </div>
</form>
